import numpy as np
from rover_navigation.perception.dataset import RandLANetDataset
from rover_navigation.util.config_loader import load_yaml
import pytest

def test_dataset_init_finds_npz_files(tmp_path):
    data_dir = tmp_path / "data"
    config_dir = tmp_path / "config"
    data_dir.mkdir()
    config_dir.mkdir()

    np.savez_compressed(
        data_dir / "sample1.npz",
        points=np.random.rand(8,3).astype(np.float32),
        features=np.random.rand(8,2).astype(np.float32),
        labels=np.random.randint(0,3, size=(8,), dtype=np.int64)
    )

    config_path = config_dir / "dataset.yaml"
    config_path.write_text(
        """
preprocessing:
  num_points: 8
  center_cloud: true
  normalize_xyz: true
  normalize_features: true
sampling:
  k_n: 2
  num_layers: 2
  sub_sampling_ratio: [2, 2]
""".strip()
    )
    
    ds = RandLANetDataset(str(data_dir), str(config_path))

    assert len(ds) == 1

