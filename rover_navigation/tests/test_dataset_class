def test_dataset_getitem_returns_expected_structure(tmp_path):
    import torch
    from rover_navigation.perception.dataset import RandLANetDataset

    data_dir = tmp_path / "data"
    config_dir = tmp_path / "config"
    data_dir.mkdir()
    config_dir.mkdir()

    np.savez_compressed(
        data_dir / "sample1.npz",
        points=np.random.rand(16, 3).astype(np.float32),
        features=np.random.rand(16, 2).astype(np.float32),
        labels=np.random.randint(0, 3, size=(16,), dtype=np.int64),
    )

    config_path = config_dir / "dataset.yaml"
    config_path.write_text(
        """
preprocessing:
  num_points: 8
  center_cloud: true
  normalize_xyz: true
  normalize_features: true
sampling:
  k_n: 2
  num_layers: 2
  sub_sampling_ratio: [2, 2]
""".strip()
    )

    ds = RandLANetDataset(str(data_dir), str(config_path))
    batch = ds[0]

    assert set(batch.keys()) == {
        "features", "labels", "xyz", "neigh_idx", "sub_idx", "interp_idx"
    }

    assert isinstance(batch["features"], torch.Tensor)
    assert isinstance(batch["labels"], torch.Tensor)

    assert batch["features"].shape == (8, 5)  # 3 xyz + 2 features
    assert batch["labels"].shape == (8,)
    assert len(batch["xyz"]) == 2
    assert len(batch["neigh_idx"]) == 2
    assert len(batch["sub_idx"]) == 2
    assert len(batch["interp_idx"]) == 2

