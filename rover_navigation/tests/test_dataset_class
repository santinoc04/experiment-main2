def test_build_hierarchy_shapes(tmp_path):
    from rover_navigation.perception.dataset import RandLANetDataset

    data_dir = tmp_path / "data"
    config_dir = tmp_path / "config"
    data_dir.mkdir()
    config_dir.mkdir()

    np.savez_compressed(
        data_dir / "sample1.npz",
        points=np.random.rand(16, 3).astype(np.float32),
        features=np.random.rand(16, 2).astype(np.float32),
        labels=np.random.randint(0, 3, size=(16,), dtype=np.int64),
    )

    config_path = config_dir / "dataset.yaml"
    config_path.write_text(
        """
preprocessing:
  num_points: 16
  center_cloud: false
  normalize_xyz: false
  normalize_features: false
sampling:
  k_n: 2
  num_layers: 2
  sub_sampling_ratio: [2, 2]
""".strip()
    )

    ds = RandLANetDataset(str(data_dir), str(config_path))
    batch = ds[0]

    for xyz in batch["xyz"]:
        assert xyz.ndim == 2
        assert xyz.shape[1] == 3

    for neigh in batch["neigh_idx"]:
        assert neigh.ndim == 2
        assert neigh.shape[1] == 2

    for sub in batch["sub_idx"]:
        assert sub.ndim == 2
        assert sub.shape[1] == 2

    for interp in batch["interp_idx"]:
        assert interp.ndim == 2
        assert interp.shape[1] == 1